# Proyecto específico - Archivos de salida ETL
# Nota: Los directorios logs/ y xlsx/ se mantienen pero sus contenidos se ignoran
logs/*.log
logs/**/*.log
xlsx/**/*.csv
xlsx/**/*.xlsx
xlsx/**/*.xlsm
xlsx/**/*.pbix

# Mantener estructura de directorios pero ignorar contenido
!logs/.gitkeep
!xlsx/SONAR/.gitkeep
!xlsx/GITLAB/.gitkeep

