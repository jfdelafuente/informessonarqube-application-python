# SonarQube Configuration
# URL de tu instancia de SonarQube (sin / al final)
SONAR_DEFAULT_HOST=https://your-sonarqube-instance.com

# Token de acceso de SonarQube
# Genera el token en: My Account > Security > Generate Tokens
SONAR_ACCESS_TOKEN=your-sonar-access-token-here

# GitLab Configuration
# URL de tu instancia de GitLab (sin / al final)
GITLAB_DEFAULT_HOST=https://your-gitlab-instance.com

# Token de acceso de GitLab
# Genera el token en: User Settings > Access Tokens
# Scopes requeridos: read_api, read_repository
GITLAB_ACCESS_TOKEN=your-gitlab-access-token-here
